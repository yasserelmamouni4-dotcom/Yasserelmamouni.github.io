<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cute Romantic Teddy Love</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* Floating hearts animation */
        .floating-heart {
            position: absolute;
            color: #ff69b4;
            font-size: 20px;
            animation: float 6s infinite linear;
            pointer-events: none;
        }

        @keyframes float {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translateY(-100px) rotate(360deg);
                opacity: 0;
            }
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
            position: relative;
            z-index: 2;
        }

        .teddy-container {
            text-align: center;
            margin-bottom: 40px;
            position: relative;
            transition: all 0.3s ease;
        }

        .teddy {
            font-size: 120px;
            animation: bounce 2s infinite;
            cursor: pointer;
            transition: transform 0.3s ease;
            display: block;
            margin: 0 auto 20px;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-20px); }
            60% { transform: translateY(-10px); }
        }

        .main-text {
            font-size: 2.5rem;
            font-weight: bold;
            background: linear-gradient(45deg, #ff6b9d, #c44569, #ff9ff3);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 50px;
            text-shadow: 2px 2px 4px rgba(255,255,255,0.5);
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { filter: drop-shadow(0 0 10px #ff69b4); }
            to { filter: drop-shadow(0 0 20px #ff1493); }
        }

        .buttons {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn {
            padding: 15px 30px;
            font-size: 1.2rem;
            font-weight: bold;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 8px 25px rgba(255, 105, 180, 0.4);
        }

        .btn-yes {
            background: linear-gradient(45deg, #ff6b9d, #c44569);
            color: white;
        }

        .btn-no {
            background: linear-gradient(45deg, #a8e6cf, #88d8a3);
            color: #333;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.5s;
        }

        .btn:hover::before {
            left: 100%;
        }

        .btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 35px rgba(255, 105, 180, 0.6);
        }

        .btn:active {
            transform: translateY(-2px) scale(1.02);
        }

        /* No button moves away */
        .btn-no {
            animation: wiggle 0.5s infinite;
        }

        @keyframes wiggle {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .btn-no.moved {
            animation: moveAway 1s ease-out forwards;
        }

        @keyframes moveAway {
            0% { transform: translateX(0); }
            100% { transform: translateX(300px) rotate(720deg); opacity: 0; }
        }

        .response {
            margin-top: 30px;
            font-size: 1.5rem;
            font-weight: bold;
            opacity: 0;
            transform: scale(0.5);
            transition: all 0.5s ease;
        }

        .response.show {
            opacity: 1;
            transform: scale(1);
        }

        .response.yes {
            color: #ff6b9d;
            background: linear-gradient(45deg, #ff9a9e, #fecfef);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .teddy {
                font-size: 80px;
            }
            
            .main-text {
                font-size: 1.8rem;
            }
            
            .buttons {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 200px;
            }
        }

        @media (max-width: 480px) {
            .teddy {
                font-size: 60px;
            }
            
            .main-text {
                font-size: 1.4rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="teddy-container">
            <div class="teddy" id="teddy">?</div>
            <div class="main-text">WASH KATBGHINI?</div>
        </div>
        
        <div class="buttons">
            <button class="btn btn-yes" onclick="showYes()">ANA TANBGHIK BZZZEF ?</button>
            <button class="btn btn-no" id="noBtn" onmouseover="moveNo()">LA</button>
        </div>
        
        <div class="response" id="response"></div>
    </div>

    <script>
        // Create floating hearts
        function createHeart() {
            const heart = document.createElement('div');
            heart.className = 'floating-heart';
            heart.innerHTML = '?';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = (Math.random() * 3 + 4) + 's';
            document.body.appendChild(heart);
            
            setTimeout(() => {
                heart.remove();
            }, 7000);
        }

        // Teddy hover interaction
        document.getElementById('teddy').addEventListener('mouseover', function() {
            this.style.transform = 'scale(1.1) rotate(10deg)';
        });

        document.getElementById('teddy').addEventListener('mouseout', function() {
            this.style.transform = 'scale(1) rotate(0deg)';
        });

        // Move NO button away
        function moveNo() {
            const noBtn = document.getElementById('noBtn');
            noBtn.classList.add('moved');
            noBtn.style.pointerEvents = 'none';
            
            // Create multiple hearts when NO is clicked/moved
            for(let i = 0; i < 10; i++) {
                setTimeout(createHeart, i * 100);
            }
            
            setTimeout(() => {
                noBtn.textContent = '? TRY AGAIN!';
                noBtn.classList.remove('moved');
                noBtn.style.opacity = '1';
                noBtn.style.transform = 'translateX(0) rotate(0deg)';
                noBtn.style.pointerEvents = 'auto';
            }, 2000);
        }

        // Show YES response
        function showYes() {
            const response = document.getElementById('response');
            response.textContent = 'YAYYY! ??? ANA TANBGHIK BZZZEF! ??';
            response.classList.add('show', 'yes');
            
            // Lots of hearts celebration
            for(let i = 0; i < 20; i++) {
                setTimeout(createHeart, i * 50);
            }
            
            // Teddy happy dance
            const teddy = document.getElementById('teddy');
            teddy.style.animation = 'none';
            setTimeout(() => {
                teddy.style.animation = 'bounce 1s infinite';
            }, 100);
        }

        // Continuous floating hearts
        setInterval(createHeart, 1000);

        // Responsive button reset for mobile
        window.addEventListener('resize', function() {
            const noBtn = document.getElementById('noBtn');
            if (noBtn.classList.contains('moved')) {
                noBtn.classList.remove('moved');
            }
        });
    </script>
</body>
</html>
